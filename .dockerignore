# Dependencies — reinstalled inside the image
**/node_modules

# Build output — rebuilt inside the image
**/dist

# Environment files — injected at runtime via docker-compose env_file
**/.env
**/.env.*

# Git history
.git
.gitignore

# Editor and OS artifacts
.DS_Store
**/.DS_Store
Thumbs.db

# Logs
**/*.log
**/npm-debug.log*

# Test output
**/coverage
**/.nyc_output

# Dev-only config
**/.eslintcache
